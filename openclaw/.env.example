# OpenClaw Gateway
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=127.0.0.1
# Must match gateway.auth.token in openclaw.json (otherwise: token mismatch on Hooks delivery)
OPENCLAW_GATEWAY_TOKEN=

# AI Provider (Primary: Anthropic. Fallback on rate limit: GPT – see deploy docs)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# DB (legal_intel for radar plugin)
DATABASE_URL=postgresql://YOUR_USER:PASSWORD@pgvector-db:5432/legal_intel

# run_scanner (optional – bot-triggered scans via Telegram)
# SCANNER_IMAGE=signal-radar_signal-radar
# SCANNER_NETWORK=radar-net

# Radar Digest (trigger-radar-digest.sh, Cron)
# openclaw.json uses ${OPENCLAW_HOOKS_TOKEN} and ${OPENCLAW_GATEWAY_TOKEN}
OPENCLAW_HOOKS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# tools.elevated.allowFrom.telegram uses ${TELEGRAM_USER_ID} (run_scanner)
TELEGRAM_USER_ID=
